<Window x:Class="ExamTest.ParticipantFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Participant Form"
        Height="380"
        Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#FFF5F7FA" Margin="16">
        <Border Padding="18"
                Background="White"
                BorderBrush="#FFD8E1EB"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock" FontSize="20" FontWeight="SemiBold" Text="Participant" />
                <TextBlock Margin="0,16,0,4" Text="Full Name" />
                <TextBox x:Name="ParticipantNameTextBox" />
                <TextBlock Margin="0,10,0,4" Text="Email" />
                <TextBox x:Name="ParticipantEmailTextBox" />
                <TextBlock Margin="0,10,0,4" Text="Phone" />
                <TextBox x:Name="ParticipantPhoneTextBox" />

                <WrapPanel Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Width="90" Margin="0,0,8,0" Click="SaveButton_Click" Content="Save" />
                    <Button Width="90" Click="CancelButton_Click" Content="Cancel" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
