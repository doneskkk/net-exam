<Window x:Class="ExamTest.RegistrationStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Registration Status"
        Height="280"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#FFF5F7FA" Margin="16">
        <Border Padding="18"
                Background="White"
                BorderBrush="#FFD8E1EB"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Update Registration Status" />
                <TextBlock x:Name="RegistrationInfoTextBlock"
                           Margin="0,16,0,6"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,10,0,4" Text="New status" />
                <ComboBox x:Name="StatusComboBox" />

                <WrapPanel Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Width="90" Margin="0,0,8,0" Click="SaveButton_Click" Content="Save" />
                    <Button Width="90" Click="CancelButton_Click" Content="Cancel" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
