<Window x:Class="ExamTest.EventFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Form"
        Height="480"
        Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#FFF5F7FA" Margin="16">
        <Border Padding="18"
                Background="White"
                BorderBrush="#FFD8E1EB"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock" FontSize="20" FontWeight="SemiBold" Text="Event" />
                <TextBlock Margin="0,16,0,4" Text="Title" />
                <TextBox x:Name="EventTitleTextBox" />
                <TextBlock Margin="0,10,0,4" Text="Type" />
                <ComboBox x:Name="EventTypeComboBox" IsEditable="True" />
                <TextBlock Margin="0,10,0,4" Text="Location" />
                <TextBox x:Name="EventLocationTextBox" />
                <TextBlock Margin="0,10,0,4" Text="Date" />
                <DatePicker x:Name="EventDatePicker" />
                <TextBlock Margin="0,10,0,4" Text="Time (HH:mm)" />
                <TextBox x:Name="EventTimeTextBox" Text="10:00" />
                <TextBlock Margin="0,10,0,4" Text="Capacity" />
                <TextBox x:Name="EventCapacityTextBox" />

                <WrapPanel Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Width="90" Margin="0,0,8,0" Click="SaveButton_Click" Content="Save" />
                    <Button Width="90" Click="CancelButton_Click" Content="Cancel" />
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
